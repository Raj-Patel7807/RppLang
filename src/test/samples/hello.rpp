let a = 999999999999999999999999999;
let b = 888888888888888888888888888;

print("A = " + a);
print("B = " + b);

print("A + B = " + (a + b));
print("A * 2 = " + (a * 2));
print("B - A = " + (b - a));

let x = 10;
let y = 999999999999999999999;
let z = 5.5;

print(x + y);
print(y + z);
print("Value: " + y);

// This is a comment;
/* this is a multiline comment */

let yy = 10;
yy = yy + 10;
print(yy);

if(yy >= 10) {
    print("Hello from if");
} else if(yy == 10) {
    print("HELLO from else if 1");
} else if(yy == 10) {
    print("HELLO FROM else if 2");
} else {
    print("HELLO from else");
}

print("FOR LOOP");
for(let i=0; i<5; i=i+1) {
    print("i = " + i);
}
print("WHILE LOOP");
let ii = 0;
while(ii < 5) {
    print("ii = " + ii);
    ii = ii + 1;
}
print("DO WHILE LOOP");
let j = 5;
do {
    print("j = " + j);
    j = j + 1;
} while(j < 5);
